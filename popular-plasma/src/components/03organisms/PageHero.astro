---
interface Props {
  title: string;
  en: string;
}

const { title, en } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero__inner">
    <p class="page-hero__en">{en}</p>
    <h1 class="page-hero__title">{title}</h1>
  </div>
</section>

<style lang="scss">
  @use '../../styles/global/functions' as *;
  @use '../../styles/global/mixin' as *;

  .page-hero {
    padding-top: 72px; // ヘッダー高さ分
    background-color: #f5f5f7;

    @include media() {
      padding-top: 60px;
    }

    &__inner {
      @include container();
      padding-top: 64px;
      padding-bottom: 64px;

      @include media() {
        padding-top: 40px;
        padding-bottom: 40px;
      }
    }

    &__en {
      font-family: font('en');
      font-size: 1.2rem;
      font-weight: weight('medium');
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: color('primary');
      margin-bottom: 8px;
    }

    &__title {
      font-size: 3.6rem;
      font-weight: weight('bold');
      letter-spacing: 0.04em;

      @include media() {
        font-size: 2.8rem;
      }
    }
  }
</style>
