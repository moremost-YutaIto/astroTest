---
const navItems = [
  { label: '事業内容', href: '/service' },
  { label: '実績', href: '/works' },
  { label: '会社情報', href: '/company' },
  { label: 'ニュース', href: '/news' },
  { label: 'お問い合わせ', href: '/contact' },
];
---

<header class="header" id="header">
  <div class="header__inner">
    <a href="/" class="header__logo">
      <span class="header__logo-text">COMPANY</span>
    </a>

    <nav class="header__nav" id="headerNav" aria-label="グローバルナビゲーション">
      <ul class="header__nav-list">
        {navItems.map((item) => (
          <li class="header__nav-item">
            <a href={item.href} class="header__nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      class="header__hamburger"
      id="hamburger"
      type="button"
      aria-expanded="false"
      aria-controls="headerNav"
      aria-label="メニューを開く"
    >
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
    </button>
  </div>
</header>

<script>
  import { fixBody, unfixBody } from '../../scripts/modules/_fixBody.js';

  const hamburger = document.getElementById('hamburger');
  const nav = document.getElementById('headerNav');

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';

    hamburger.setAttribute('aria-expanded', String(!isOpen));
    hamburger.setAttribute('aria-label', isOpen ? 'メニューを開く' : 'メニューを閉じる');
    nav?.classList.toggle('is-open', !isOpen);
    hamburger.classList.toggle('is-open', !isOpen);

    isOpen ? unfixBody() : fixBody();
  });

  // ナビリンクを押したら閉じる
  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      nav.classList.remove('is-open');
      hamburger?.classList.remove('is-open');
      unfixBody();
    });
  });
</script>

<style lang="scss">
  @use '../../styles/global/functions' as *;
  @use '../../styles/global/mixin' as *;

  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background-color: color('white');
    border-bottom: 1px solid color('gray');

    &__inner {
      @include container();
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;

      @include media() {
        height: 60px;
      }
    }

    &__logo {
      text-decoration: none;
    }

    &__logo-text {
      font-family: font('en');
      font-size: 2rem;
      font-weight: weight('bold');
      letter-spacing: 0.1em;
      color: color('fontPrimary');
    }

    // PC ナビ
    &__nav {
      @include media() {
        position: fixed;
        inset: 0;
        background-color: color('white');
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s easing('easeOutCubic');

        &.is-open {
          opacity: 1;
          pointer-events: auto;
        }
      }
    }

    &__nav-list {
      display: flex;
      gap: 32px;

      @include media() {
        flex-direction: column;
        align-items: center;
        gap: 32px;
      }
    }

    &__nav-link {
      font-size: 1.4rem;
      font-weight: weight('medium');
      letter-spacing: 0.06em;
      color: color('fontPrimary');
      text-decoration: none;
      position: relative;

      &::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background-color: color('primary');
        transition: width 0.2s easing('easeOutCubic');
      }

      &:hover {
        opacity: 1;

        &::after {
          width: 100%;
        }
      }

      @include media() {
        font-size: 1.8rem;
      }
    }

    // ハンバーガー
    &__hamburger {
      display: none;
      width: 40px;
      height: 40px;
      flex-direction: column;
      justify-content: center;
      gap: 6px;
      padding: 8px;
      position: relative;
      z-index: 101;

      @include media() {
        display: flex;
      }
    }

    &__hamburger-line {
      display: block;
      width: 100%;
      height: 1px;
      background-color: color('fontPrimary');
      transform-origin: center;
      transition: transform 0.3s easing('easeOutCubic'), opacity 0.3s;
    }

    &__hamburger {
      &.is-open {
        .header__hamburger-line {
          &:nth-child(1) {
            transform: translateY(7px) rotate(45deg);
          }
          &:nth-child(2) {
            opacity: 0;
          }
          &:nth-child(3) {
            transform: translateY(-7px) rotate(-45deg);
          }
        }
      }
    }
  }
</style>
