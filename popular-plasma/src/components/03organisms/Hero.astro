---
interface Props {
  title?: string;
  subtitle?: string;
  image?: string;
}

const {
  title = 'ビジネスに、\n新しい可能性を。',
  subtitle = 'We create digital experiences that inspire.',
  image,
} = Astro.props;
---

<section class="hero">
  <div class="hero__bg">
    {image
      ? <img src={image} alt="" class="hero__bg-image" />
      : <div class="hero__bg-placeholder" aria-hidden="true"></div>
    }
    <div class="hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="hero__inner">
    <div class="hero__content">
      <p class="hero__subtitle">{subtitle}</p>
      <h1 class="hero__title" set:html={title.replace(/\n/g, '<br />')} />
      <a href="/contact" class="hero__cta">お問い合わせ</a>
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-text">SCROLL</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style lang="scss">
  @use '../../styles/global/functions' as *;
  @use '../../styles/global/mixin' as *;

  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    display: flex;
    align-items: center;

    &__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    &__bg-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    &__bg-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    }

    &__overlay {
      position: absolute;
      inset: 0;
      background-color: rgba(0, 0, 0, 0.4);
    }

    &__inner {
      @include container();
      position: relative;
      z-index: 1;
      width: 100%;
    }

    &__content {
      max-width: 640px;
    }

    &__subtitle {
      font-family: font('en');
      font-size: 1.3rem;
      font-weight: weight('medium');
      letter-spacing: 0.15em;
      color: color('primary');
      margin-bottom: 16px;
    }

    &__title {
      font-size: 5.6rem;
      font-weight: weight('bold');
      line-height: 1.3;
      letter-spacing: 0.02em;
      color: color('white');
      margin-bottom: 48px;

      @include media() {
        font-size: 3.6rem;
      }
    }

    &__cta {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-size: 1.5rem;
      font-weight: weight('medium');
      color: color('white');
      text-decoration: none;
      border: 1px solid rgba(255, 255, 255, 0.6);
      padding: 14px 32px;
      transition: background-color 0.2s easing('easeOutCubic'), border-color 0.2s;

      &::after {
        content: '';
        display: inline-block;
        width: 24px;
        height: 1px;
        background-color: currentColor;
        position: relative;
      }

      &:hover {
        opacity: 1;
        background-color: color('primary');
        border-color: color('primary');
      }
    }

    // スクロールインジケーター
    &__scroll {
      position: absolute;
      bottom: 32px;
      right: 40px;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;

      @include media() {
        display: none;
      }
    }

    &__scroll-text {
      font-family: font('en');
      font-size: 1rem;
      font-weight: weight('medium');
      letter-spacing: 0.15em;
      color: rgba(255, 255, 255, 0.6);
      writing-mode: vertical-rl;
    }

    &__scroll-line {
      display: block;
      width: 1px;
      height: 48px;
      background: linear-gradient(to bottom, rgba(255,255,255,0.6), transparent);
      animation: scrollLine 1.6s easing('easeOutCubic') infinite;
    }

    @keyframes scrollLine {
      0% { transform: scaleY(0); transform-origin: top; }
      50% { transform: scaleY(1); transform-origin: top; }
      51% { transform: scaleY(1); transform-origin: bottom; }
      100% { transform: scaleY(0); transform-origin: bottom; }
    }
  }
</style>
