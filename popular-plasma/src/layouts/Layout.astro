---
import '../styles/style.scss';
import Header from '../components/03organisms/Header.astro';
import Footer from '../components/03organisms/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'サイトタイトル',
  description = 'サイトの説明文',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
