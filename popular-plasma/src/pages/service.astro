---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/03organisms/PageHero.astro';
import Heading from '../components/01atoms/Heading.astro';
import Btn from '../components/01atoms/Btn.astro';

const services = [
  {
    number: '01',
    title: 'Webサイト制作',
    body: 'コーポレートサイト・ランディングページ・ECサイトなど、目的に合わせた最適なWebサイトを制作します。デザインから実装・公開まで一貫して対応します。',
    tags: ['デザイン', 'フロントエンド', 'WordPress', 'Astro'],
  },
  {
    number: '02',
    title: 'Webアプリケーション開発',
    body: '業務効率化・顧客管理・予約システムなど、ビジネス課題を解決するWebアプリケーションを開発します。要件定義から運用保守まで対応します。',
    tags: ['React', 'Next.js', 'TypeScript', 'API開発'],
  },
  {
    number: '03',
    title: 'UI/UXデザイン',
    body: 'ユーザー体験を重視したUI設計・デザインシステム構築を行います。Figmaを用いたデザインカンプ作成からプロトタイピングまで対応します。',
    tags: ['Figma', 'デザインシステム', 'プロトタイプ'],
  },
];
---

<Layout title="事業内容 | COMPANY" description="私たちが提供するサービスをご紹介します。">
  <PageHero title="事業内容" en="Service" />

  <section class="service-list">
    <div class="service-list__inner">
      {services.map((service) => (
        <article class="service-item">
          <span class="service-item__number">{service.number}</span>
          <div class="service-item__body">
            <h2 class="service-item__title">{service.title}</h2>
            <p class="service-item__text">{service.body}</p>
            <ul class="service-item__tags">
              {service.tags.map((tag) => (
                <li class="service-item__tag">{tag}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="service-cta">
    <div class="service-cta__inner">
      <Heading en="Contact" align="center">まずはお気軽にご相談ください</Heading>
      <p class="service-cta__text">
        ご要望・ご予算に合わせて最適なご提案をいたします。<br />
        お見積もりは無料です。
      </p>
      <Btn href="/contact" variant="primary" size="lg">お問い合わせ</Btn>
    </div>
  </section>
</Layout>

<style lang="scss">
  @use '../styles/global/functions' as *;
  @use '../styles/global/mixin' as *;

  .service-list {
    padding: 96px 0;

    @include media() {
      padding: 64px 0;
    }

    &__inner {
      @include container();
      display: flex;
      flex-direction: column;
      gap: 64px;

      @include media() {
        gap: 48px;
      }
    }
  }

  .service-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 32px;
    padding-bottom: 64px;
    border-bottom: 1px solid color('gray');

    @include media() {
      grid-template-columns: 1fr;
      gap: 16px;
      padding-bottom: 48px;
    }

    &:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    &__number {
      font-family: font('en');
      font-size: 4.8rem;
      font-weight: weight('bold');
      color: color('gray');
      line-height: 1;
      padding-top: 4px;
    }

    &__title {
      font-size: 2.4rem;
      font-weight: weight('bold');
      margin-bottom: 16px;
    }

    &__text {
      font-size: 1.5rem;
      line-height: 1.9;
      color: color('fontPrimary');
      margin-bottom: 24px;
    }

    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    &__tag {
      font-size: 1.2rem;
      padding: 4px 12px;
      border: 1px solid color('gray');
      border-radius: 2px;
      color: color('fontPrimary');
    }
  }

  .service-cta {
    padding: 96px 0;
    background-color: #f5f5f7;

    @include media() {
      padding: 64px 0;
    }

    &__inner {
      @include container();
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
      text-align: center;
    }

    &__text {
      font-size: 1.5rem;
      line-height: 1.9;
    }
  }
</style>
